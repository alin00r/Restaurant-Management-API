{
  "version": 2,
  "name": "Restaurant-Management-API",
  "builds": [
    {
      "src": "dist/main.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["node_modules/swagger-ui-dist/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "\/(.*)",
      "dest": "dist/main.js"
    }
  ]
}
